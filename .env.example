# ─── Шаг 1: Telegram Bot Token ────────────────────────────────────────────────
# Получить у @BotFather → /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Шаг 2: Google Sheets ID ──────────────────────────────────────────────────
# Создать таблицу на https://sheets.google.com
# ID находится в URL: docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ─── Шаг 3: Путь к файлу credentials.json ────────────────────────────────────
# По умолчанию ищет credentials.json рядом с bot.py
# Как получить:
#   1. Открыть https://console.cloud.google.com
#   2. Создать проект → Включить Google Sheets API и Google Drive API
#   3. IAM и администрирование → Сервисные аккаунты → Создать аккаунт
#   4. Скачать JSON-ключ → сохранить как credentials.json рядом с bot.py
#   5. Открыть таблицу → Доступ → добавить email сервисного аккаунта (роль Редактор)
GOOGLE_CREDENTIALS_FILE=credentials.json
